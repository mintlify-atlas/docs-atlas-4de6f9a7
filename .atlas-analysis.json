  "keyFeatures": [
    "Full data lifecycle - fetch metadata, download databases, and query results in-memory",
    "Runtime configuration with API credentials, WASM paths, and custom fetch implementations",
    "Content processing utilities for Arabic book content with Shamela-specific formatting",
    "Environment-aware WASM bundle selection for Node.js, browsers, and bundlers",
    "Lightweight content-only export for client-side use without sql.js overhead",
    "Support for both JSON and SQLite output formats"
  ],
